# Get your key from https://online.nimbleway.com/
NIMBLE_API_KEY=your_api_key_here

# ClickHouse Cloud — hostname from your service settings + password/API key
CLICKHOUSE_HOST=your-cluster.region.gcp.clickhouse.cloud
CLICKHOUSE_API_KEY=your_clickhouse_password
# Aliases also supported: CLICKHOUSE_PASSWORD, or CLICKHOUSE_URL=https://default:pass@host:8443/default
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true

# OpenRouter — web /api/chat + npm run dev (pi agent)
OPENROUTER_API_KEY=your_openrouter_key

# Playwright Craigslist fallback
PLAYWRIGHT_HEADLESS=true
