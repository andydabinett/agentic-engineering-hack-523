# Copy to .env and fill in values. Never commit .env.

# --- Nimble (listing ingestion) ---
# https://online.nimbleway.com/
NIMBLE_API_KEY=

# --- Correspondence server ---
# Demo walkthrough: DEMO.md
PORT=3001
# Local API base URL only. Do not point this at ngrok — webhook signatures use
# ngrok forwarded headers, and Twilio webhook URL is synced via npm run sync:twilio-webhook.
PUBLIC_BASE_URL=http://localhost:3001
CORRESPONDENCE_DEV=0

# Twilio SMS — https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional: skip phone-number lookup when syncing webhook URL
# TWILIO_PHONE_NUMBER_SID=

# OpenRouter — web /api/chat + pi agent + correspondence LLM
OPENROUTER_API_KEY=

# --- ClickHouse ---
CLICKHOUSE_HOST=
CLICKHOUSE_API_KEY=
# Aliases also supported: CLICKHOUSE_PASSWORD, or CLICKHOUSE_URL=https://default:pass@host:8443/default
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=javier
CLICKHOUSE_SECURE=true

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_REFRESH_TOKEN=

# Playwright Craigslist fallback
PLAYWRIGHT_HEADLESS=true

# Always-on crawler (npm run crawler, or CRAWLER_ENABLED=1 in Docker)
# CRAWLER_ENABLED=1
# CRAWLER_BOROUGHS=all
# CRAWLER_SOURCES=craigslist,streeteasy
# CRAWLER_INGEST_INTERVAL=2m
# CRAWLER_VERIFY_INTERVAL=1h
# CRAWLER_MAX_RESULTS=5
# CRAWLER_RUN_VERIFY=1
# CRAWLER_SYNC_CLICKHOUSE=1

# Dashboard live poll interval (ms) — new Craigslist matches appear without refresh
# NEXT_PUBLIC_LISTINGS_POLL_MS=20000
