{
  "name": "javier-nyc-rent-concierge",
  "version": "0.1.0",
  "private": true,
  "description": "NYC rent concierge — Nimble ingest, ClickHouse analytics, SMS correspondence, Next.js dashboard",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "./dev.sh",
    "dev:agent": "./dev.sh",
    "server": "npx tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:correspondence": "npx tsx scripts/demo-correspondence.ts",
    "demo:fake-correspondence": "npx tsx scripts/demo-fake-correspondence.ts",
    "server:fake": "CORRESPONDENCE_FAKE_DEMO=1 CORRESPONDENCE_DEV=1 npx tsx src/index.ts",
    "sync:twilio-webhook": "npx tsx scripts/sync-twilio-webhook.ts",
    "dev:correspondence": "bash scripts/dev-correspondence.sh",
    "dev:correspondence:ui": "bash scripts/dev-correspondence-ui.sh",
    "init:clickhouse": "npx tsx scripts/init_clickhouse.ts",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "start:web": "cd web && npm run start",
    "dev:stack": "bash scripts/dev-stack.sh",
    "clickhouse:migrate": "node scripts/clickhouse-migrate.js",
    "sync:clickhouse": "node scripts/sync-clickhouse.js",
    "seed:demo": "node scripts/seed-demo.js",
    "test:clickhouse": "node scripts/test-clickhouse.js",
    "test:zillow": "node scripts/test-zillow-scrape.js",
    "ingest": "node scripts/ingest-boroughs.js",
    "ingest:brooklyn": "node scripts/ingest-boroughs.js --boroughs brooklyn --max-results 3 --depth deep",
    "ingest:east-village": "node scripts/ingest-east-village.js",
    "contacts": "node scripts/list-contacts.js",
    "test:craigslist-phone": "node scripts/test-craigslist-phone.js",
    "playwright:install": "playwright install chromium",
    "verify": "node scripts/verify-listings.js",
    "crawler": "node scripts/crawl-daemon.js",
    "crawler:once": "node scripts/crawl-daemon.js --once",
    "start:prod": "bash scripts/start-production.sh"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.5",
    "@hono/node-server": "^2.0.3",
    "@mariozechner/pi-coding-agent": "0.73.1",
    "dotenv": "^17.4.2",
    "googleapis": "^172.0.0",
    "hono": "^4.12.22",
    "playwright": "^1.51.0",
    "twilio": "^6.0.2",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
