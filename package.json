{
  "name": "javier-nyc-rent-concierge",
  "version": "0.1.0",
  "private": true,
  "description": "NYC rent concierge — Nimble ingest, ClickHouse analytics, listing verification, Next.js dashboard",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "./dev.sh",
    "dev:agent": "./dev.sh",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "start:web": "cd web && npm run start",
    "dev:stack": "npm run web:dev",
    "clickhouse:migrate": "node scripts/clickhouse-migrate.js",
    "sync:clickhouse": "node scripts/sync-clickhouse.js",
    "test:clickhouse": "node scripts/test-clickhouse.js",
    "test:zillow": "node scripts/test-zillow-scrape.js",
    "ingest": "node scripts/ingest-boroughs.js",
    "ingest:brooklyn": "node scripts/ingest-boroughs.js --boroughs brooklyn --max-results 3 --depth deep",
    "ingest:east-village": "node scripts/ingest-east-village.js",
    "contacts": "node scripts/list-contacts.js",
    "test:craigslist-phone": "node scripts/test-craigslist-phone.js",
    "playwright:install": "playwright install chromium",
    "verify": "node scripts/verify-listings.js",
    "crawler": "node scripts/crawl-daemon.js",
    "crawler:once": "node scripts/crawl-daemon.js --once",
    "start:prod": "bash scripts/start-production.sh"
  },
  "dependencies": {
    "@clickhouse/client": "^1.10.1",
    "@mariozechner/pi-coding-agent": "0.73.1",
    "dotenv": "^16.4.7",
    "playwright": "^1.51.0"
  }
}
