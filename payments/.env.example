# Coinbase Developer Platform (CDP) API Key
CDP_API_KEY_NAME=your_api_key_name
CDP_API_KEY_PRIVATE_KEY="-----BEGIN ZILLION PRIVATE KEY-----\n...\n-----END ZILLION PRIVATE KEY-----"

# Coinbase Network Configuration (defaults to base-sepolia)
CDP_NETWORK=base-sepolia

# Escrow Wallet ID (automatically created and persisted on first run if missing)
ESCROW_WALLET_ID=

# Server Port
PORT=8787

# SQLite Database File Path
DATABASE_PATH=./payments.db
